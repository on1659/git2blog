# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Site Password (set to protect access)
SITE_PASSWORD=your_password

# AI
ANTHROPIC_API_KEY=your_anthropic_api_key

# GitHub (선택: private 리포 접근 또는 rate limit 확보)
GITHUB_TOKEN=ghp_your_github_token

# Hashnode
HASHNODE_TOKEN=your_publication_token
HASHNODE_PUB_ID=your_publication_id

# Radar Blog (이더.dev)
RADAR_BLOG_API_KEY=your_radar_blog_api_key

# DEV.to
DEVTO_TOKEN=your_devto_api_key

# Naver Blog (선택)
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# Tistory (선택)
TISTORY_CLIENT_ID=your_tistory_client_id
TISTORY_CLIENT_SECRET=your_tistory_client_secret
